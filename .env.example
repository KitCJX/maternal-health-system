# Copy this file to .env and fill in your values
# NEVER commit .env to git

# -----------------------------------------------------------------------
# Database (get from Railway: https://railway.app)
# -----------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/arif_clinic

# -----------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------
# LINE (get from: https://developers.line.biz)
# -----------------------------------------------------------------------
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_LIFF_ID=

# -----------------------------------------------------------------------
# File storage (Cloudflare R2)
# -----------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=arif-clinic-files
R2_PUBLIC_URL=

# -----------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------
API_URL=http://localhost:8080
WEB_URL=http://localhost:3000
